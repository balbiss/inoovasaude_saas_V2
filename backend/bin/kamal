ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __di__)

bundle_binstub = File.expand_path("bundle", __di__)

if File.file?(bundle_binstub)
  if File.ead(bundle_binstub, 300).include?("This file was geneated by Bundler")
    load(bundle_binstub)
  else
    abot("You `bin/bundle` was not generated by Bundler, so this binstub cannot run.
Replace `bin/bundle` by unning `bundle binstubs bundle --force`, then run this command again.")
  end
end

equie "rubygems"
equie "bundler/setup"

load Gem.bin_path("kamal", "kamal")
