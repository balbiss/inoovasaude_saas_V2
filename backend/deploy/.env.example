# ================================================================
# CRM IMOBILIÁRIO — CONFIGURAÇÃO
# Copie para .env e preencha todos os campos obrigatórios
# ================================================================


# ── SUA MARCA ───────────────────────────────────────────────────
APP_NAME=Nome do Seu CRM                        # ← obrigatório
APP_LOGO_URL=https://seusite.com/logo.png       # URL pública da logo
APP_PRIMARY_COLOR=#1f93ff                       # cor principal (hex)
APP_ACCENT_COLOR=#8b5cf6                        # cor de destaque (hex)
APP_SUPPORT_EMAIL=suporte@seusite.com           # ← obrigatório
APP_FOOTER_TEXT=© 2025 Sua Empresa. Todos os direitos reservados.


# ── SEUS DOMÍNIOS ────────────────────────────────────────────────
# Configure esses dois domínios no seu DNS apontando para o IP do VPS
FRONTEND_URL=https://crm.seudominio.com.br      # ← obrigatório
BACKEND_URL=https://api.seudominio.com.br       # ← obrigatório


# ── BANCO DE DADOS ───────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=                              # ← obrigatório — senha forte
POSTGRES_DB=crm_production


# ── SEGURANÇA RAILS ──────────────────────────────────────────────
# Gere cada um com o comando:
# openssl rand -hex 64
RAILS_MASTER_KEY=                              # ← obrigatório
SECRET_KEY_BASE=                               # ← obrigatório


# ── WHATSAPP ─────────────────────────────────────────────────────
# Qualquer string aleatória — serve como senha da API do WhatsApp
BAILEYS_API_KEY=                               # ← obrigatório


# ── E-MAIL (recuperação de senha) ───────────────────────────────
# Hostinger: smtp.hostinger.com, porta 587
SMTP_USER=suporte@visitaia.com.br          # ← seu e-mail Hostinger
SMTP_PASSWORD=                             # ← senha do e-mail Hostinger
SMTP_DOMAIN=visitaia.com.br


# ── INTELIGÊNCIA ARTIFICIAL (opcional) ───────────────────────────
OPENAI_API_KEY=
