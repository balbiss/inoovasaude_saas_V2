# ================================================================
# CRM IMOBILIÁRIO — CONFIGURAÇÃO DE INSTALAÇÃO
# ================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha TODOS os campos marcados com ← OBRIGATÓRIO
# 3. Suba o sistema: docker compose -f docker-compose.prod.yml up -d
# ================================================================


# ── MARCA DA SUA EMPRESA ────────────────────────────────────────
APP_NAME="Nome do Seu CRM"                  # ← OBRIGATÓRIO
APP_LOGO_URL="https://seusite.com/logo.png" # URL pública da sua logo
APP_PRIMARY_COLOR="#1f93ff"                 # Cor principal (hex)
APP_ACCENT_COLOR="#8b5cf6"                  # Cor de destaque (hex)
APP_SUPPORT_EMAIL="suporte@seusite.com"     # ← OBRIGATÓRIO
APP_FOOTER_TEXT="© 2025 Sua Empresa. Todos os direitos reservados."


# ── DOMÍNIOS ────────────────────────────────────────────────────
FRONTEND_URL=https://crm.seudominio.com     # ← OBRIGATÓRIO
BACKEND_URL=https://api.seudominio.com      # ← OBRIGATÓRIO


# ── BANCO DE DADOS ──────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=troque_essa_senha_agora   # ← OBRIGATÓRIO
POSTGRES_DB=crm_production


# ── RAILS ───────────────────────────────────────────────────────
# Gere com: docker run --rm ruby:3.2-alpine ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
RAILS_MASTER_KEY=                           # ← OBRIGATÓRIO
SECRET_KEY_BASE=                            # ← OBRIGATÓRIO (mesmo comando acima)


# ── WHATSAPP (BAILEYS) ──────────────────────────────────────────
BAILEYS_API_KEY=troque_essa_chave_secreta   # ← OBRIGATÓRIO — qualquer string aleatória


# ── INTELIGÊNCIA ARTIFICIAL (OPCIONAL) ──────────────────────────
# Deixe em branco se não for usar a IA
OPENAI_API_KEY=
